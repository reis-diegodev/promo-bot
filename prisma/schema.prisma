generator client {
  provider      = "prisma-client-js"
  // Adicionamos 'debian-openssl-3.0.x' que é o padrão do Ubuntu 22.04 (Jammy) usado na imagem
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Promotion {
  id          Int      @id @default(autoincrement())
  title       String
  price       String   // String para manter formatação (R$ 1.200,00)
  url         String
  urlHash     String   @unique // Hash MD5 da URL ou ID do produto para evitar duplicatas
  createdAt   DateTime @default(now())
  sentToGroup Boolean  @default(false)

  @@map("promotions")
}